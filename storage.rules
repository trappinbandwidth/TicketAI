rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ticket images: only the owning driver can read/write
    match /tickets/{driverId}/{ticketId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == driverId;
      allow write: if request.auth != null
                   && request.auth.uid == driverId
                   && request.resource.size < 15 * 1024 * 1024   // 15 MB max per file
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
