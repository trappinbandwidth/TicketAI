rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each driver can only read/write their own subtree
    match /drivers/{driverId} {
      allow read, write: if request.auth != null && request.auth.uid == driverId;

      match /tickets/{ticketId} {
        allow read: if request.auth != null && request.auth.uid == driverId;
        // Drivers can create tickets; AI engine (admin SDK) handles updates
        allow create: if request.auth != null && request.auth.uid == driverId;
        // No client-side updates — all field updates come from the AI engine via Admin SDK
        allow update, delete: if false;
      }
    }

    // Attorney + carrier portals: any authenticated user can read the top-level
    // tickets collection. Status filtering (exclude "AI Review") is done in the
    // portal query layer. Only the AI engine (Admin SDK) writes here.
    match /tickets/{ticketId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
