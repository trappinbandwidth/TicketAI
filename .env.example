ANTHROPIC_API_KEY=sk-ant-...
PROMPT_VERSION=v2
USE_MOCK=true
API_KEY=cdl-local-dev

# Firebase Admin SDK
# Option A: paste the full service account JSON as one line (easiest for local dev)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: set project ID and use Application Default Credentials (GCE / Cloud Run)
FIREBASE_PROJECT_ID=
